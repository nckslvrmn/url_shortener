{
  "name": "URL Shortener",
  "description": "Shorten the current page URL using s.slvr.io",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": ["activeTab"],
  "host_permissions": ["https://s.slvr.io/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shorten this URL"
  }
}
